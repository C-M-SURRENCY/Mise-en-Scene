---
const posts = await Astro.glob('./posts/*.md');

const normalizedPosts = posts
  .map((post) => ({
    ...post,
    title: post.frontmatter.title || 'Untitled Film',
    director: post.frontmatter.director || 'Unknown Director',
    year: post.frontmatter.year || 'Unknown Year',
    rating: post.frontmatter.rating || 'Unrated',
    poster: post.frontmatter.poster || '',
    date: post.frontmatter.date || '1900-01-01',
    featured: post.frontmatter.featured === true,
    dek:
      post.frontmatter.dek ||
      post.frontmatter.description ||
      post.frontmatter.summary ||
      post.frontmatter.excerpt ||
      'A critical dispatch from the archive.',
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const leadFeature =
  normalizedPosts.find((post) => post.featured) ||
  normalizedPosts[0] ||
  null;

const LeadContent = leadFeature?.Content;
const recentPosts = normalizedPosts.filter((post) => post !== leadFeature).slice(0, 3);
const archivePosts = normalizedPosts;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mise-en-Scène | Film Journal</title>
  <meta
    name="description"
    content="A refined film journal for criticism, visual essays, and close readings of cinema."
  />

  <style>
    :root {
      --bg: #0d1112;
      --bg-2: #14191b;
      --panel: rgba(20, 25, 27, 0.82);
      --panel-2: rgba(27, 32, 35, 0.82);
      --ink: #f2eee6;
      --muted: #a7adb0;
      --quiet: #727b80;
      --line: rgba(255, 255, 255, 0.11);
      --line-strong: rgba(255, 255, 255, 0.2);
      --gold: #d7b56d;
      --wine: #623339;
      --wine-2: #42262b;
      --serif: Georgia, "Times New Roman", serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --shadow: 0 34px 90px rgba(0, 0, 0, 0.48);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      background: var(--bg);
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      font-family: var(--serif);
      line-height: 1.68;
      background:
        radial-gradient(circle at 16% 0%, rgba(215, 181, 109, 0.1), transparent 34rem),
        radial-gradient(circle at 86% 16%, rgba(98, 51, 57, 0.2), transparent 30rem),
        linear-gradient(180deg, #171c1f 0%, #0d1112 46%, #090c0d 100%);
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0 0 auto 0;
      height: 18px;
      z-index: 100;
      pointer-events: none;
      background: linear-gradient(90deg, var(--wine-2), var(--wine), var(--wine-2));
      box-shadow: 0 10px 28px rgba(98, 51, 57, 0.38);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      display: block;
      max-width: 100%;
    }

    .shell {
      width: min(1520px, calc(100% - 48px));
      margin: 0 auto;
      padding-top: 18px;
    }

    .topbar {
      position: relative;
      z-index: 10;
      border: 1px solid var(--line);
      background:
        linear-gradient(90deg, rgba(10, 14, 15, 0.98), rgba(17, 22, 24, 0.96));
      box-shadow: 0 22px 60px rgba(0, 0, 0, 0.34);
    }

    .topbar-inner {
      min-height: 78px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
      padding: 0 34px;
    }

    .brand {
      font-family: var(--sans);
      font-size: 0.86rem;
      font-weight: 800;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 18px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav a {
      transition: color 180ms ease;
    }

    .nav a:hover {
      color: var(--ink);
    }

    .dot {
      color: rgba(215, 181, 109, 0.78);
      letter-spacing: 0;
    }

    .hero {
      min-height: 560px;
      display: grid;
      align-items: end;
      padding: 112px 0 82px;
      border-bottom: 1px solid var(--line);
    }

    .eyebrow {
      margin: 0 0 20px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.38em;
      text-transform: uppercase;
    }

    h1 {
      max-width: 1120px;
      margin: 0;
      font-size: clamp(4.25rem, 10vw, 10.6rem);
      line-height: 0.86;
      font-weight: 400;
      letter-spacing: 0;
    }

    .intro {
      max-width: 820px;
      margin: 34px 0 0;
      color: #d9ddd8;
      font-family: var(--sans);
      font-size: clamp(1.02rem, 1.45vw, 1.18rem);
      line-height: 1.85;
    }

    .index-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid var(--line);
    }

    .index-item {
      padding: 24px 26px;
      border-right: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.018);
    }

    .index-item:last-child {
      border-right: 0;
    }

    .index-label {
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .index-value {
      margin-top: 8px;
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.42rem;
      line-height: 1.2;
    }

    section {
      padding: 78px 0;
      border-bottom: 1px solid var(--line);
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 24px;
      margin-bottom: 36px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
    }

    .section-title::after {
      content: "";
      height: 1px;
      flex: 1;
      background: var(--line);
    }

    .featured {
      display: grid;
      grid-template-columns: minmax(320px, 0.88fr) minmax(380px, 1.12fr);
      gap: clamp(36px, 5.4vw, 86px);
      align-items: center;
    }

    .poster {
      overflow: hidden;
      border: 1px solid var(--line-strong);
      background: #050707;
      box-shadow: var(--shadow);
    }

    .poster img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      opacity: 0.94;
      filter: saturate(0.92) contrast(1.04);
      transition: transform 600ms ease, opacity 300ms ease;
    }

    .poster:hover img {
      transform: scale(1.025);
      opacity: 1;
    }

    .poster-empty {
      min-height: 560px;
      display: grid;
      place-items: center;
      color: var(--quiet);
      font-family: var(--sans);
      background:
        linear-gradient(135deg, rgba(215, 181, 109, 0.08), transparent),
        #050707;
    }

    .feature-kicker {
      margin: 0 0 14px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    .feature-title {
      margin: 0;
      font-size: clamp(2.8rem, 5vw, 5.7rem);
      line-height: 0.96;
      font-weight: 400;
      letter-spacing: 0;
    }

    .meta {
      margin: 20px 0 28px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .feature-copy {
      max-width: 760px;
      color: #d8ddd9;
      font-size: 1.15rem;
    }

    .feature-copy :global(p:first-child) {
      margin-top: 0;
    }

    .score-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 30px;
    }

    .score {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      min-height: 46px;
      padding: 0 16px;
      border: 1px solid rgba(215, 181, 109, 0.36);
      background: rgba(215, 181, 109, 0.075);
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.76rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .score strong {
      color: var(--ink);
      letter-spacing: 0.08em;
    }

    .reviews {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 26px;
    }

    .review-card {
      border: 1px solid var(--line);
      background: rgba(20, 25, 27, 0.72);
      transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
    }

    .review-card:hover {
      transform: translateY(-5px);
      border-color: var(--line-strong);
      background: rgba(27, 32, 35, 0.92);
    }

    .review-image {
      border-bottom: 1px solid var(--line);
      background: #050707;
    }

    .review-image img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      opacity: 0.92;
      filter: saturate(0.9) contrast(1.04);
    }

    .review-body {
      padding: 25px;
    }

    .review-body h3 {
      margin: 0;
      font-size: clamp(1.62rem, 2vw, 2.15rem);
      line-height: 1.05;
      font-weight: 400;
      letter-spacing: 0;
    }

    .review-body p {
      margin: 18px 0 0;
      color: #c8cfcb;
      font-size: 1rem;
    }

    .archive-panel {
      border: 1px solid var(--line);
      background: rgba(20, 25, 27, 0.74);
      box-shadow: 0 26px 70px rgba(0, 0, 0, 0.3);
    }

    .archive-tools {
      padding: 24px;
      border-bottom: 1px solid var(--line);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 18px;
      align-items: center;
    }

    #searchBar {
      width: 100%;
      min-height: 56px;
      border: 1px solid var(--line);
      border-radius: 0;
      padding: 0 18px;
      color: var(--ink);
      background: rgba(7, 10, 11, 0.76);
      font-family: var(--sans);
      font-size: 0.92rem;
      outline: none;
    }

    #searchBar:focus {
      border-color: rgba(215, 181, 109, 0.65);
    }

    .archive-count {
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .archive-header,
    .archive-row {
      display: grid;
      grid-template-columns: 2fr 1.35fr 0.7fr 0.7fr;
      gap: 18px;
      align-items: center;
    }

    .archive-header {
      padding: 16px 24px;
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--line);
    }

    .archive-row {
      padding: 20px 24px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.065);
      transition: background 180ms ease;
    }

    .archive-row:hover {
      background: rgba(255, 255, 255, 0.035);
    }

    .archive-row:last-child {
      border-bottom: 0;
    }

    .archive-title {
      font-size: 1.24rem;
      line-height: 1.25;
    }

    .archive-director,
    .archive-year {
      color: #c2c9c5;
      font-family: var(--sans);
      font-size: 0.88rem;
    }

    .archive-rating {
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .empty,
    .no-results {
      padding: 46px 24px;
      color: var(--muted);
      text-align: center;
      font-family: var(--sans);
    }

    .no-results {
      display: none;
    }

    footer {
      padding: 42px 0 56px;
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.24em;
      text-align: center;
      text-transform: uppercase;
    }

    @media (max-width: 960px) {
      .shell {
        width: min(100% - 28px, 1520px);
      }

      .topbar-inner {
        min-height: auto;
        padding: 18px;
        align-items: flex-start;
        flex-direction: column;
      }

      .nav {
        width: 100%;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 10px 14px;
        white-space: normal;
        letter-spacing: 0.18em;
        line-height: 1.5;
      }

      .hero {
        min-height: 440px;
        padding: 78px 0 62px;
      }

      .index-strip,
      .featured,
      .reviews {
        grid-template-columns: 1fr;
      }

      .index-item {
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }

      .index-item:last-child {
        border-bottom: 0;
      }

      .poster-empty {
        min-height: 390px;
      }

      .archive-tools {
        grid-template-columns: 1fr;
      }

      .archive-header {
        display: none;
      }

      .archive-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .archive-director::before {
        content: "Director: ";
        color: var(--quiet);
      }

      .archive-year::before {
        content: "Year: ";
        color: var(--quiet);
      }

      .archive-rating::before {
        content: "Score: ";
        color: var(--quiet);
      }
    }
  </style>
</head>

<body>
  <div class="shell">
    <nav class="topbar" aria-label="Primary navigation">
      <div class="topbar-inner">
        <a class="brand" href="#">Mise-en-Scène</a>

        <div class="nav">
          <a href="#featured">Featured Review</a>
          <span class="dot">•</span>
          <a href="#recent">Recent Additions</a>
          <span class="dot">•</span>
          <a href="#archive">The Archive</a>
        </div>
      </div>
    </nav>

    <header class="hero">
      <div>
        <p class="eyebrow">A journal of cinema, memory, and image-making</p>
        <h1>Mise-en-Scène</h1>
        <p class="intro">
          A refined notebook for films that linger after the final frame:
          studies in atmosphere, performance, composition, silence, obsession,
          and the private weather of cinema.
        </p>
      </div>
    </header>

    <div class="index-strip" aria-label="Journal summary">
      <div class="index-item">
        <div class="index-label">Editorial Focus</div>
        <div class="index-value">Close readings of modern and classic cinema</div>
      </div>
      <div class="index-item">
        <div class="index-label">Archive</div>
        <div class="index-value">{archivePosts.length} cataloged dispatches</div>
      </div>
      <div class="index-item">
        <div class="index-label">Publisher</div>
        <div class="index-value">Cayden Mcguire Surrency</div>
      </div>
    </div>

    <main>
      <section id="featured">
        <div class="section-title">
          <span>Featured Analysis</span>
        </div>

        {leadFeature ? (
          <div class="featured">
            <div class="poster">
              {leadFeature.poster ? (
                <img src={leadFeature.poster} alt={`Poster for ${leadFeature.title}`} loading="eager" />
              ) : (
                <div class="poster-empty">No Poster Available</div>
              )}
            </div>

            <article>
              <p class="feature-kicker">Current Selection</p>
              <h2 class="feature-title">{leadFeature.title}</h2>

              <div class="meta">
                {leadFeature.year} / Directed by {leadFeature.director}
              </div>

              <div class="feature-copy">
                {LeadContent ? <LeadContent /> : <p>{leadFeature.dek}</p>}
              </div>

              <div class="score-row">
                <div class="score">
                  Review Score <strong>{leadFeature.rating} / 4.0</strong>
                </div>
              </div>
            </article>
          </div>
        ) : (
          <div class="empty">
            The editorial catalog is currently empty. Add markdown reviews to begin.
          </div>
        )}
      </section>

      <section id="recent">
        <div class="section-title">
          <span>Recent Additions</span>
        </div>

        {recentPosts.length > 0 ? (
          <div class="reviews">
            {recentPosts.map((post) => (
              <article class="review-card">
                <div class="review-image">
                  {post.poster ? (
                    <img src={post.poster} alt={`Poster for ${post.title}`} loading="lazy" />
                  ) : (
                    <div class="poster-empty">No Poster</div>
                  )}
                </div>

                <div class="review-body">
                  <h3>{post.title}</h3>
                  <div class="meta">
                    {post.year} / {post.director} / {post.rating} out of 4
                  </div>
                  <p>{post.dek}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty">No recent auxiliary essays cataloged.</div>
        )}
      </section>

      <section id="archive">
        <div class="section-title">
          <span>The Archive</span>
        </div>

        <div class="archive-panel">
          <div class="archive-tools">
            <input
              type="search"
              id="searchBar"
              placeholder="Search by film, director, or year"
              aria-label="Search the archive"
            />
            <div class="archive-count">{archivePosts.length} entries</div>
          </div>

          <div class="archive-header">
            <div>Film Title</div>
            <div>Director</div>
            <div>Year</div>
            <div>Score</div>
          </div>

          <div id="archiveCatalog">
            {archivePosts.map((post) => (
              <div
                class="archive-row"
                data-title={post.title}
                data-director={post.director}
                data-year={post.year}
              >
                <div class="archive-title">{post.title}</div>
                <div class="archive-director">{post.director}</div>
                <div class="archive-year">{post.year}</div>
                <div class="archive-rating">{post.rating} / 4.0</div>
              </div>
            ))}
          </div>

          <div class="no-results" id="noResults">
            No entries match your search.
          </div>
        </div>
      </section>
    </main>

    <footer>
      Edited and published by Cayden Mcguire Surrency / © 2026 Mise-en-Scène
    </footer>
  </div>

  <script>
    const searchBar = document.getElementById('searchBar');
    const archiveCatalog = document.getElementById('archiveCatalog');
    const noResults = document.getElementById('noResults');

    if (searchBar && archiveCatalog && noResults) {
      const rows = Array.from(archiveCatalog.querySelectorAll('.archive-row'));

      searchBar.addEventListener('input', () => {
        const query = searchBar.value.toLowerCase().trim();
        let matches = 0;

        rows.forEach((row) => {
          const title = row.getAttribute('data-title')?.toLowerCase() || '';
          const director = row.getAttribute('data-director')?.toLowerCase() || '';
          const year = row.getAttribute('data-year')?.toLowerCase() || '';

          const visible =
            title.includes(query) ||
            director.includes(query) ||
            year.includes(query);

          row.style.display = visible ? 'grid' : 'none';

          if (visible) {
            matches += 1;
          }
        });

        noResults.style.display = matches === 0 && query !== '' ? 'block' : 'none';
      });
    }
  </script>
</body>
</html>
