---
const posts = await Astro.glob('./posts/*.md');

const entries = posts
  .map((post) => ({
    ...post,
    title: post.frontmatter.title || 'Untitled Film',
    director: post.frontmatter.director || 'Unknown Director',
    year: post.frontmatter.year || 'Unknown Year',
    rating: post.frontmatter.rating || 'Unrated',
    poster: post.frontmatter.poster || '',
    date: post.frontmatter.date || '1900-01-01',
    featured: post.frontmatter.featured === true,
    excerpt:
      post.frontmatter.excerpt ||
      post.frontmatter.description ||
      post.frontmatter.summary ||
      'A study in image, gesture, atmosphere, and the afterlife of a film.',
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const featured = entries.find((entry) => entry.featured) || entries[0] || null;
const FeaturedContent = featured?.Content;
const recent = entries.filter((entry) => entry !== featured).slice(0, 3);
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mise-en-Scène | Film Journal</title>
  <meta name="description" content="A refined film journal of criticism, close readings, and cinematic essays." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #0c0e0f;
      --bg-soft: #141718;
      --panel: rgba(255, 255, 255, 0.035);
      --panel-strong: rgba(255, 255, 255, 0.065);
      --text: #f1ece2;
      --muted: #a8aaa6;
      --quiet: #747874;
      --line: rgba(241, 236, 226, 0.12);
      --line-strong: rgba(241, 236, 226, 0.22);
      --gold: #c9a968;
      --wine: #5a3034;
      --serif: "Cormorant Garamond", Georgia, serif;
      --sans: "Inter", system-ui, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      background: var(--bg);
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      font-family: var(--serif);
      background:
        radial-gradient(circle at 20% 0%, rgba(201, 169, 104, 0.08), transparent 34rem),
        radial-gradient(circle at 90% 12%, rgba(90, 48, 52, 0.2), transparent 32rem),
        linear-gradient(180deg, #171a1b 0%, #0c0e0f 48%, #080909 100%);
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      display: block;
      max-width: 100%;
    }

    .shell {
      width: min(1480px, calc(100% - 48px));
      margin: 0 auto;
    }

    .topbar {
      position: static;
      border-bottom: 1px solid var(--line);
    }

    .topbar-inner {
      min-height: 92px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
    }

    .brand {
      font-family: var(--sans);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.32em;
      text-transform: uppercase;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 18px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav a {
      transition: color 180ms ease;
    }

    .nav a:hover {
      color: var(--text);
    }

    .dot {
      color: var(--gold);
      letter-spacing: 0;
    }

    .hero {
      min-height: 620px;
      display: grid;
      align-items: center;
      border-bottom: 1px solid var(--line);
      padding: 78px 0 92px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: clamp(42px, 7vw, 110px);
      align-items: end;
    }

    .eyebrow {
      margin: 0 0 22px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      max-width: 980px;
      font-size: clamp(5.2rem, 12vw, 12.4rem);
      line-height: 0.78;
      font-weight: 500;
      letter-spacing: 0;
    }

    .intro {
      max-width: 620px;
      margin: 0;
      color: #d4d0c7;
      font-family: var(--sans);
      font-size: clamp(1rem, 1.35vw, 1.15rem);
      line-height: 1.9;
    }

    .journal-note {
      margin-top: 34px;
      padding-top: 22px;
      border-top: 1px solid var(--line);
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.75rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid var(--line);
    }

    .stat {
      padding: 26px 28px;
      border-right: 1px solid var(--line);
    }

    .stat:last-child {
      border-right: 0;
    }

    .stat-label {
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
    }

    .stat-value {
      margin-top: 8px;
      font-size: 1.55rem;
      line-height: 1.12;
    }

    section {
      padding: 86px 0;
      border-bottom: 1px solid var(--line);
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 24px;
      margin-bottom: 40px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
    }

    .section-title::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--line);
    }

    .feature {
      display: grid;
      grid-template-columns: minmax(300px, 0.86fr) minmax(380px, 1.14fr);
      gap: clamp(42px, 6vw, 92px);
      align-items: center;
    }

    .poster {
      overflow: hidden;
      border: 1px solid var(--line-strong);
      background: #050505;
      box-shadow: 0 34px 100px rgba(0, 0, 0, 0.52);
    }

    .poster img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      opacity: 0.94;
      filter: saturate(0.88) contrast(1.06);
    }

    .poster-empty {
      min-height: 560px;
      display: grid;
      place-items: center;
      color: var(--quiet);
      font-family: var(--sans);
      background: #050505;
    }

    .feature-label {
      margin: 0 0 16px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .feature-title {
      margin: 0;
      font-size: clamp(3rem, 5.6vw, 6.4rem);
      line-height: 0.9;
      font-weight: 500;
    }

    .meta {
      margin: 22px 0 30px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .feature-copy {
      max-width: 780px;
      color: #d8d5cd;
      font-size: 1.28rem;
      line-height: 1.75;
    }

    .feature-copy :global(p:first-child) {
      margin-top: 0;
    }

    .score {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      margin-top: 30px;
      min-height: 46px;
      padding: 0 16px;
      border: 1px solid rgba(201, 169, 104, 0.38);
      color: var(--gold);
      background: rgba(201, 169, 104, 0.07);
      font-family: var(--sans);
      font-size: 0.74rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .score strong {
      color: var(--text);
    }

    .reviews {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px;
    }

    .review {
      border: 1px solid var(--line);
      background: var(--panel);
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }

    .review:hover {
      transform: translateY(-4px);
      border-color: var(--line-strong);
      background: var(--panel-strong);
    }

    .review img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      filter: saturate(0.9) contrast(1.04);
    }

    .review-body {
      padding: 26px;
      border-top: 1px solid var(--line);
    }

    .review h3 {
      margin: 0;
      font-size: 2rem;
      line-height: 1;
      font-weight: 500;
    }

    .review p {
      margin: 18px 0 0;
      color: #c9c6be;
      font-size: 1.05rem;
      line-height: 1.65;
    }

    .archive {
      border: 1px solid var(--line);
      background: var(--panel);
    }

    .archive-tools {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 18px;
      align-items: center;
      padding: 24px;
      border-bottom: 1px solid var(--line);
    }

    #searchBar {
      width: 100%;
      min-height: 56px;
      border: 1px solid var(--line);
      border-radius: 0;
      padding: 0 18px;
      color: var(--text);
      background: rgba(0, 0, 0, 0.22);
      font-family: var(--sans);
      font-size: 0.92rem;
      outline: none;
    }

    #searchBar:focus {
      border-color: rgba(201, 169, 104, 0.72);
    }

    .archive-count {
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .archive-header,
    .archive-row {
      display: grid;
      grid-template-columns: 2fr 1.35fr 0.7fr 0.7fr;
      gap: 18px;
      align-items: center;
    }

    .archive-header {
      padding: 16px 24px;
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--line);
    }

    .archive-row {
      padding: 21px 24px;
      border-bottom: 1px solid rgba(241, 236, 226, 0.07);
    }

    .archive-row:last-child {
      border-bottom: 0;
    }

    .archive-row:hover {
      background: rgba(255, 255, 255, 0.035);
    }

    .archive-title {
      font-size: 1.35rem;
      line-height: 1.15;
    }

    .archive-director,
    .archive-year {
      color: #c9c6be;
      font-family: var(--sans);
      font-size: 0.88rem;
    }

    .archive-rating {
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .empty,
    .no-results {
      padding: 46px 24px;
      color: var(--muted);
      text-align: center;
      font-family: var(--sans);
    }

    .no-results {
      display: none;
    }

    footer {
      padding: 42px 0 58px;
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.24em;
      text-align: center;
      text-transform: uppercase;
    }

    @media (max-width: 940px) {
      .shell {
        width: min(100% - 28px, 1480px);
      }

      .topbar-inner {
        min-height: auto;
        padding: 22px 0;
        align-items: flex-start;
        flex-direction: column;
      }

      .nav {
        flex-wrap: wrap;
        white-space: normal;
        gap: 10px 14px;
        line-height: 1.5;
        letter-spacing: 0.18em;
      }

      .hero {
        min-height: 520px;
        padding: 64px 0 70px;
      }

      .hero-grid,
      .feature,
      .reviews,
      .stats {
        grid-template-columns: 1fr;
      }

      .intro {
        margin-top: 10px;
      }

      .stat {
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }

      .stat:last-child {
        border-bottom: 0;
      }

      .archive-tools {
        grid-template-columns: 1fr;
      }

      .archive-header {
        display: none;
      }

      .archive-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .archive-director::before {
        content: "Director: ";
        color: var(--quiet);
      }

      .archive-year::before {
        content: "Year: ";
        color: var(--quiet);
      }

      .archive-rating::before {
        content: "Score: ";
        color: var(--quiet);
      }
    }
  </style>
</head>

<body>
  <div class="shell">
    <nav class="topbar" aria-label="Primary navigation">
      <div class="topbar-inner">
        <a class="brand" href="#">Mise-en-Scène</a>

        <div class="nav">
          <a href="#featured">Featured Review</a>
          <span class="dot">•</span>
          <a href="#recent">Recent Additions</a>
          <span class="dot">•</span>
          <a href="#archive">The Archive</a>
        </div>
      </div>
    </nav>

    <header class="hero">
      <div class="hero-grid">
        <div>
          <p class="eyebrow">A private journal of cinema and image-making</p>
          <h1>Mise-en-Scène</h1>
        </div>

        <div>
          <p class="intro">
            Essays for films that remain after the final frame: studies in atmosphere,
            gesture, architecture, silence, obsession, performance, and the strange
            emotional weather of cinema.
          </p>
          <div class="journal-note">
            Edited and published by Cayden Mcguire Surrency
          </div>
        </div>
      </div>
    </header>

    <div class="stats" aria-label="Journal overview">
      <div class="stat">
        <div class="stat-label">Editorial Mode</div>
        <div class="stat-value">Close readings and critical essays</div>
      </div>
      <div class="stat">
        <div class="stat-label">Archive</div>
        <div class="stat-value">{entries.length} cataloged dispatches</div>
      </div>
      <div class="stat">
        <div class="stat-label">Focus</div>
        <div class="stat-value">Modern cinema, classics, and cult objects</div>
      </div>
    </div>

    <main>
      <section id="featured">
        <div class="section-title">
          <span>Featured Analysis</span>
        </div>

        {featured ? (
          <div class="feature">
            <div class="poster">
              {featured.poster ? (
                <img src={featured.poster} alt={`Poster for ${featured.title}`} loading="eager" />
              ) : (
                <div class="poster-empty">No Poster Available</div>
              )}
            </div>

            <article>
              <p class="feature-label">Current Selection</p>
              <h2 class="feature-title">{featured.title}</h2>

              <div class="meta">
                {featured.year} / Directed by {featured.director}
              </div>

              <div class="feature-copy">
                {FeaturedContent ? <FeaturedContent /> : <p>{featured.excerpt}</p>}
              </div>

              <div class="score">
                Review Score <strong>{featured.rating} / 4.0</strong>
              </div>
            </article>
          </div>
        ) : (
          <div class="empty">The editorial catalog is currently empty.</div>
        )}
      </section>

      <section id="recent">
        <div class="section-title">
          <span>Recent Additions</span>
        </div>

        {recent.length > 0 ? (
          <div class="reviews">
            {recent.map((post) => (
              <article class="review">
                {post.poster ? (
                  <img src={post.poster} alt={`Poster for ${post.title}`} loading="lazy" />
                ) : (
                  <div class="poster-empty">No Poster</div>
                )}

                <div class="review-body">
                  <h3>{post.title}</h3>
                  <div class="meta">
                    {post.year} / {post.director} / {post.rating} out of 4
                  </div>
                  <p>{post.excerpt}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty">No recent auxiliary essays cataloged.</div>
        )}
      </section>

      <section id="archive">
        <div class="section-title">
          <span>The Archive</span>
        </div>

        <div class="archive">
          <div class="archive-tools">
            <input
              type="search"
              id="searchBar"
              placeholder="Search by film, director, or year"
              aria-label="Search the archive"
            />
            <div class="archive-count">{entries.length} entries</div>
          </div>

          <div class="archive-header">
            <div>Film Title</div>
            <div>Director</div>
            <div>Year</div>
            <div>Score</div>
          </div>

          <div id="archiveCatalog">
            {entries.map((post) => (
              <div
                class="archive-row"
                data-title={post.title}
                data-director={post.director}
                data-year={post.year}
              >
                <div class="archive-title">{post.title}</div>
                <div class="archive-director">{post.director}</div>
                <div class="archive-year">{post.year}</div>
                <div class="archive-rating">{post.rating} / 4.0</div>
              </div>
            ))}
          </div>

          <div class="no-results" id="noResults">
            No entries match your search.
          </div>
        </div>
      </section>
    </main>

    <footer>
      Edited and published by Cayden Mcguire Surrency / © 2026 Mise-en-Scène
    </footer>
  </div>

  <script>
    const searchBar = document.getElementById('searchBar');
    const archiveCatalog = document.getElementById('archiveCatalog');
    const noResults = document.getElementById('noResults');

    if (searchBar && archiveCatalog && noResults) {
      const rows = Array.from(archiveCatalog.querySelectorAll('.archive-row'));

      searchBar.addEventListener('input', () => {
        const query = searchBar.value.toLowerCase().trim();
        let matches = 0;

        rows.forEach((row) => {
          const title = row.getAttribute('data-title')?.toLowerCase() || '';
          const director = row.getAttribute('data-director')?.toLowerCase() || '';
          const year = row.getAttribute('data-year')?.toLowerCase() || '';

          const visible =
            title.includes(query) ||
            director.includes(query) ||
            year.includes(query);

          row.style.display = visible ? 'grid' : 'none';

          if (visible) matches += 1;
        });

        noResults.style.display = matches === 0 && query !== '' ? 'block' : 'none';
      });
    }
  </script>
</body>
</html>
