---
// Fetch all markdown dispatches dynamically from the posts folder
const posts = await Astro.glob('./posts/*.md');

// Sort posts chronologically (Newest First)
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date || 0) - new Date(a.frontmatter.date || 0));

// Editorial Hierarchy Filtering with fallback protection
const leadFeature = sortedPosts.find(post => post.frontmatter.featured === true) || sortedPosts[0] || null;
const secondaryFeatures = sortedPosts.filter(post => post !== leadFeature).slice(0, 3);
const archivalCatalog = sortedPosts; 
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Mise-en-Scène | Film Journal</title>
	
	<script type="application/ld+json" set:html={JSON.stringify({
	  "@context": "https://schema.org/",
	  "@type": "Review",
	  "itemReviewed": {
	    "@type": "Movie",
	    "name": leadFeature?.frontmatter?.title || "Mise-en-Scène",
	    "director": {
	      "@type": "Person",
	      "name": leadFeature?.frontmatter?.director || "Cinema"
	    },
	    "dateCreated": leadFeature?.frontmatter?.year || "2026"
	  },
	  "reviewRating": {
	    "@type": "Rating",
	    "ratingValue": leadFeature?.frontmatter?.rating || "4.0",
	    "bestRating": "4.0",
	    "worstRating": "0.0"
	  },
	  "author": {
	    "@type": "Person",
	    "name": "Cayden Mcguire Surrency"
	  },
	  "publisher": {
	    "@type": "Organization",
	    "name": "Mise-en-Scène",
	    "url": "https://your-movie-journal.vercel.app"
	  }
	})} />

	<style>
		/* --- LUXURY HIGH-END DESIGN SYSTEM --- */
		:root {
			--bg: #0e1113;                  /* Deep Obsidian Slate */
			--bg-gradient: radial-gradient(circle at top, #1a1f24 0%, #0e1113 70%);
			--panel: rgba(22, 27, 31, 0.6); /* Translucent Charcoal */
			--panel-hover: rgba(30, 37, 43, 0.8);
			--text: #eef2f5;                /* Crisp Off-White */
			--text-muted: #8a99a6;          /* Muted Silver-Grey */
			--border: rgba(255, 255, 255, 0.05);
			--border-hover: rgba(255, 255, 255, 0.15);
			--gold: #dfba73;
			--gold-gradient: linear-gradient(135deg, #fff 30%, #dfba73 100%);
			--serif: "Baskerville", "Playfair Display", "Times New Roman", serif;
			--sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, sans-serif;
		}
		
		html { scroll-behavior: smooth; }

		body { 
			background: var(--bg);
			background-image: var(--bg-gradient);
			color: var(--text); 
			font-family: var(--serif); 
			max-width: 1240px; 
			margin: 0 auto; 
			padding: 0 40px 60px 40px; 
			letter-spacing: 0.01em;
			line-height: 1.7;
			-webkit-font-smoothing: antialiased;
		}

		/* --- BLURRED STICKY NAVIGATION --- */
		.sticky-nav {
			position: sticky;
			top: 0;
			background: rgba(14, 17, 19, 0.75);
			backdrop-filter: blur(20px);
			-webkit-backdrop-filter: blur(20px);
			z-index: 100;
			border-bottom: 1px solid var(--border);
			padding: 20px 0;
			display: flex;
			justify-content: space-between;
			align-items: center;
			font-family: var(--sans);
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 3px;
			color: var(--text-muted);
		}
		.sticky-nav a { color: var(--text-muted); text-decoration: none; transition: color 0.3s ease; }
		.sticky-nav a:hover { color: var(--text); }

		/* --- MASTHEAD WITH METALLIC GRADIENT --- */
		header {
			padding: 100px 0 60px 0;
			text-align: center;
			position: relative;
		}
		h1 { 
			font-weight: normal; 
			font-size: 5.5rem; 
			margin: 0; 
			letter-spacing: 8px; 
			text-transform: uppercase;
			line-height: 1;
			background: var(--gold-gradient);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			display: inline-block;
		}
		.tagline { 
			color: var(--text-muted); 
			font-size: 0.75rem; 
			margin-top: 20px; 
			text-transform: uppercase; 
			letter-spacing: 6px; 
			font-family: var(--sans);
		}

		/* --- SECTION STYLING --- */
		section { margin-bottom: 100px; }
		.section-title {
			font-family: var(--sans);
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 3px;
			color: var(--text-muted);
			border-bottom: 1px solid var(--border);
			padding-bottom: 14px;
			margin-bottom: 45px;
			display: flex;
			justify-content: space-between;
		}

		/* --- FEATURED REVIEWS (Hero Layout) --- */
		.lead-feature-grid {
			display: grid;
			grid-template-columns: 1.14fr 1fr;
			gap: 60px;
			align-items: flex-start;
		}
		@media (max-width: 960px) { .lead-feature-grid { grid-template-columns: 1fr; gap: 40px; } }
		
		.lead-poster {
			border: 1px solid var(--border);
			border-radius: 8px;
			box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
			overflow: hidden;
			background: #000;
			transition: border-color 0.4s ease, box-shadow 0.4s ease;
		}
		.lead-poster:hover { 
			border-color: rgba(255, 255, 255, 0.15); 
			box-shadow: 0 30px 60px rgba(223, 186, 115, 0.1);
		}
		.lead-poster img { 
			width: 100%; 
			height: auto; 
			display: block;
			opacity: 0.88;
			transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s;
		}
		.lead-poster:hover img { transform: scale(1.015); opacity: 1; }
		
		.lead-title { font-size: 3.4rem; margin: 0 0 12px 0; font-weight: normal; line-height: 1.1; color: var(--text); }
		.lead-meta { font-family: var(--sans); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 25px; }
		.lead-text { font-size: 1.2rem; color: #ced7de; text-align: justify; margin-bottom: 35px; }
		
		/* Velvet Rating Pill */
		.rating-display {
			font-family: var(--sans);
			font-size: 0.8rem;
			letter-spacing: 2px;
			text-transform: uppercase;
			display: inline-flex;
			align-items: center;
			gap: 8px;
			border: 1px solid rgba(223, 186, 115, 0.2);
			padding: 8px 18px;
			background: linear-gradient(135deg, rgba(22,27,31,0.8) 0%, rgba(14,17,19,0.8) 100%);
			border-radius: 4px;
			color: var(--gold);
		}
		.rating-display strong { color: var(--text); font-size: 0.95rem; }

		/* --- RECENT DISPATCHES GRID --- */
		.secondary-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
			gap: 50px;
		}
		.secondary-card { 
			background: var(--panel); 
			border: 1px solid var(--border);
			border-radius: 8px;
			padding: 24px;
			transition: background 0.3s, border-color 0.3s, transform 0.3s;
		}
		.secondary-card:hover {
			background: var(--panel-hover);
			border-color: var(--border-hover);
			transform: translateY(-4px);
		}
		.secondary-poster { 
			border-radius: 4px;
			overflow: hidden; 
			background: #000;
			margin-bottom: 24px;
			box-shadow: 0 15px 30px rgba(0,0,0,0.3);
		}
		.secondary-poster img { 
			width: 100%; 
			height: 440px; 
			object-fit: cover; 
			opacity: 0.85;
			transition: opacity 0.3s, transform 0.4s;
		}
		.secondary-card:hover .secondary-poster img { opacity: 1; transform: scale(1.02); }
		.secondary-title { font-size: 1.9rem; margin: 0 0 8px 0; font-weight: normal; color: var(--text); }
		.secondary-text { font-size: 1.05rem; color: #b8c4cf; text-align: justify; }

		/* --- FILTERABLE LOG ARCHIVE --- */
		.archive-wrapper { 
			background: var(--panel); 
			border: 1px solid var(--border); 
			padding: 40px; 
			border-radius: 8px; 
			box-shadow: 0 20px 40px rgba(0,0,0,0.2);
		}
		.archive-controls { margin-bottom: 40px; }
		#searchBar {
			width: 100%;
			box-sizing: border-box;
			padding: 18px 24px;
			background: rgba(14, 17, 19, 0.6);
			border: 1px solid var(--border);
			color: var(--text);
			font-family: var(--sans);
			font-size: 0.85rem;
			letter-spacing: 1.5px;
			border-radius: 6px;
			outline: none;
			transition: border-color 0.3s, background 0.3s;
		}
		#searchBar:focus { border-color: rgba(223, 186, 115, 0.4); background: rgba(14, 17, 19, 0.9); }
		
		.archive-table { display: flex; flex-direction: column; }
		.archive-header {
			display: grid;
			grid-template-columns: 2fr 1.5fr 1fr 1fr;
			font-family: var(--sans);
			font-size: 0.7rem;
			text-transform: uppercase;
			letter-spacing: 2px;
			color: var(--text-muted);
			padding: 14px 20px;
			border-bottom: 1px solid rgba(255,255,255,0.1);
		}
		.archive-row {
			display: grid;
			grid-template-columns: 2fr 1.5fr 1fr 1fr;
			align-items: center;
			padding: 22px 20px;
			border-bottom: 1px solid var(--border);
			font-size: 1.05rem;
			transition: background 0.2s, transform 0.2s;
		}
		.archive-row:hover { 
			background: rgba(255, 255, 255, 0.02); 
			transform: translateX(4px);
		}
		.archive-title { font-weight: normal; font-family: var(--serif); font-size: 1.3rem; color: var(--text); }
		.archive-director { font-family: var(--sans); font-size: 0.85rem; color: #a2b0bc; }
		.archive-year { font-family: var(--sans); font-size: 0.85rem; color: var(--text-muted); }
		.archive-rating { font-family: var(--sans); font-size: 0.85rem; color: var(--gold); font-weight: 600; }
		
		.no-results { display: none; text-align: center; padding: 40px; color: var(--text-muted); font-family: var(--sans); font-size: 0.85rem;}
		.empty-notice { text-align: center; padding: 60px 20px; color: var(--text-muted); font-style: italic; border: 1px dashed var(--border); border-radius: 8px;}

		/* --- EDITORIAL FOOTER CREDIT --- */
		footer {
			border-top: 1px solid var(--border);
			padding-top: 30px;
			margin-top: 40px;
			text-align: center;
			font-family: var(--sans);
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 2px;
			color: var(--text-muted);
		}
	</style>
</head>
<body>

	<nav class="sticky-nav">
		<div style="font-weight: 600; color: #fff; letter-spacing: 2px;">Mise-en-Scène</div>
		<div>
			<a href="#featured">Featured Review</a> • 
			<a href="#recent">Recent Additions</a> • 
			<a href="#archive">The Archive</a>
		</div>
	</nav>

	<header>
		<h1>Mise-en-Scène</h1>
		<div class="tagline">Essays and Criticisms on Modern Cinema</div>
	</header>

	<section id="featured">
		<div class="section-title">
			<span>Featured Analysis</span>
		</div>
		{leadFeature ? (
			<div class="lead-feature-grid">
				<div class="lead-poster">
					{leadFeature.frontmatter.poster ? (
						<img src={leadFeature.frontmatter.poster} alt={`Cinematic poster for ${leadFeature.frontmatter.title}`} />
					) : (
						<div style="height: 550px; background: #000; display:flex; align-items:center; justify-content:center; color:var(--text-muted);">No Poster Available</div>
					)}
				</div>
				<div class="lead-essay-preview">
					<h2 class="lead-title">{leadFeature.frontmatter.title}</h2>
					<div class="lead-meta">
						Year of Production: {leadFeature.frontmatter.year} &nbsp;•&nbsp; Directed by {leadFeature.frontmatter.director}
					</div>
					<div class="lead-text"><leadFeature.Content /></div>
					<div class="rating-display">
						Review Score: <strong>{leadFeature.frontmatter.rating} / 4.0</strong>
					</div>
				</div>
			</div>
		) : (
			<div class="empty-notice">The editorial catalog is currently empty. New dispatches will populate automatically.</div>
		)}
	</section>

	<section id="recent">
		<div class="section-title">
			<span>Recent Additions</span>
		</div>
		{secondaryFeatures.length > 0 ? (
			<div class="secondary-grid">
				{secondaryFeatures.map(post => (
					<div class="secondary-card">
						<div class="secondary-poster">
							{post.frontmatter.poster ? (
								<img src={post.frontmatter.poster} alt={`Cinematic poster for ${post.frontmatter.title}`} />
							) : (
								<div style="height: 440px; background: #000; display:flex; align-items:center; justify-content:center; color:var(--text-muted);">No Poster</div>
							)}
						</div>
						<h3 class="secondary-title">{post.frontmatter.title} ({post.frontmatter.year})</h3>
						<div class="lead-meta" style="margin-bottom:16px;">Dir. {post.frontmatter.director} &nbsp;//&nbsp; Score: {post.frontmatter.rating}/4.0</div>
						<div class="secondary-text"><post.Content /></div>
					</div>
				))}
			</div>
		) : (
			<div class="empty-notice">No recent auxiliary essays cataloged.</div>
		)}
	</section>

	<section id="archive">
		<div class="section-title">
			<span>The Archive</span>
		</div>
		
		<div class="archive-wrapper">
			<div class="archive-controls">
				<input type="text" id="searchBar" placeholder="Search the archive by title, auteur, or release year..." />
			</div>

			<div class="archive-table">
				<div class="archive-header">
					<div>Film Title</div>
					<div>Director</div>
					<div>Year</div>
					<div>Score</div>
				</div>

				<div id="archiveCatalog">
					{archivalCatalog.map(post => (
						<div class="archive-row" data-title={post.frontmatter.title} data-director={post.frontmatter.director} data-year={post.frontmatter.year}>
							<div class="archive-title">{post.frontmatter.title}</div>
							<div class="archive-director">{post.frontmatter.director}</div>
							<div class="archive-year">{post.frontmatter.year}</div>
							<div class="archive-rating">{post.frontmatter.rating} / 4.0</div>
						</div>
					))}
				</div>
			</div>
			
			<div class="no-results" id="noResults">No entries match your filtering parameters.</div>
		</div>
	</section>

	<footer>
		Edited and Published by Cayden Mcguire Surrency // © 2026 Mise-en-Scène
	</footer>

	<script>
		const searchBar = document.getElementById('searchBar');
		const archiveCatalog = document.getElementById('archiveCatalog');
		const noResults = document.getElementById('noResults');

		if (searchBar && archiveCatalog) {
			const rows = archiveCatalog.getElementsByClassName('archive-row');
			
			searchBar.addEventListener('keyup', (e) => {
				const target = e.target as HTMLInputElement;
				const query = target.value.toLowerCase();
				let matches = 0;

				Array.from(rows).forEach(row => {
					const element = row as HTMLElement;
					const title = element.getAttribute('data-title')?.toLowerCase() || '';
					const director = element.getAttribute('data-director')?.toLowerCase() || '';
					const year = element.getAttribute('data-year')?.toLowerCase() || '';

					if (title.includes(query) || director.includes(query) || year.includes(query)) {
						element.style.display = 'grid';
						matches++;
					} else {
						element.style.display = 'none';
					}
				});

				if (noResults) {
					noResults.style.display = (matches === 0 && query !== '') ? 'block' : 'none';
				}
			});
		}
	</script>
</body>
</html>
