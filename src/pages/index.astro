---
const posts = await Astro.glob('./posts/*.md');

const entries = posts
  .map((post) => ({
    ...post,
    title: post.frontmatter.title || 'Untitled Film',
    director: post.frontmatter.director || 'Unknown Director',
    year: post.frontmatter.year || 'Unknown Year',
    rating: post.frontmatter.rating || 'Unrated',
    poster: post.frontmatter.poster || '',
    date: post.frontmatter.date || '1900-01-01',
    featured: post.frontmatter.featured === true,
    excerpt:
      post.frontmatter.excerpt ||
      post.frontmatter.description ||
      post.frontmatter.summary ||
      'A study in image, atmosphere, performance, and the afterlife of a film.',
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const featured = entries.find((entry) => entry.featured) || entries[0] || null;
const FeaturedContent = featured?.Content;
const recent = entries.filter((entry) => entry !== featured).slice(0, 3);
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mise-en-Scène | Film Journal</title>
  <meta
    name="description"
    content="A refined cinema journal of criticism, close readings, and film essays."
  />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #0d0f0f;
      --bg-soft: #151716;
      --panel: rgba(255, 255, 255, 0.035);
      --panel-strong: rgba(255, 255, 255, 0.065);
      --text: #f0eadf;
      --body: #ddd6ca;
      --muted: #aaa79f;
      --quiet: #77746d;
      --line: rgba(240, 234, 223, 0.13);
      --line-strong: rgba(240, 234, 223, 0.24);
      --gold: #c7a45d;
      --wine: #5a3034;
      --display: "Instrument Serif", Georgia, serif;
      --serif: "Source Serif 4", Georgia, serif;
      --sans: "Inter", system-ui, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      background: var(--bg);
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      font-family: var(--serif);
      background:
        radial-gradient(circle at 18% 0%, rgba(199, 164, 93, 0.085), transparent 34rem),
        radial-gradient(circle at 92% 8%, rgba(90, 48, 52, 0.2), transparent 30rem),
        linear-gradient(180deg, #171917 0%, #0d0f0f 44%, #090a0a 100%);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      display: block;
      max-width: 100%;
    }

    .shell {
      width: min(1440px, calc(100% - 48px));
      margin: 0 auto;
    }

    .topbar {
      position: static;
      border-bottom: 1px solid var(--line);
    }

    .topbar-inner {
      min-height: 86px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
    }

    .brand {
      font-family: var(--sans);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 18px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.7rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav a {
      transition: color 180ms ease;
    }

    .nav a:hover {
      color: var(--text);
    }

    .dot {
      color: var(--gold);
      letter-spacing: 0;
    }

    .hero {
      padding: clamp(72px, 10vw, 138px) 0 clamp(76px, 9vw, 120px);
      border-bottom: 1px solid var(--line);
    }

    .eyebrow {
      margin: 0 0 24px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-family: var(--display);
      font-size: clamp(4.8rem, 10.2vw, 11rem);
      line-height: 0.86;
      font-weight: 400;
      letter-spacing: 0.01em;
      white-space: nowrap;
    }

    .hero-copy {
      display: grid;
      grid-template-columns: minmax(0, 0.82fr) minmax(360px, 0.5fr);
      gap: clamp(36px, 6vw, 90px);
      align-items: end;
      margin-top: 38px;
    }

    .intro {
      max-width: 760px;
      margin: 0;
      color: var(--body);
      font-family: var(--serif);
      font-size: clamp(1.18rem, 1.8vw, 1.55rem);
      line-height: 1.65;
    }

    .note {
      margin: 0;
      padding-top: 18px;
      border-top: 1px solid var(--line);
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      line-height: 1.8;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    section {
      padding: clamp(72px, 8vw, 104px) 0;
      border-bottom: 1px solid var(--line);
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 24px;
      margin-bottom: 42px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
    }

    .section-title::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--line);
    }

    .feature {
      display: grid;
      grid-template-columns: minmax(300px, 0.82fr) minmax(420px, 1.18fr);
      gap: clamp(42px, 6vw, 94px);
      align-items: start;
    }

    .poster {
      overflow: hidden;
      border: 1px solid var(--line-strong);
      background: #050505;
      box-shadow: 0 34px 100px rgba(0, 0, 0, 0.5);
    }

    .poster img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      opacity: 0.95;
      filter: saturate(0.9) contrast(1.06);
    }

    .poster-empty {
      min-height: 540px;
      display: grid;
      place-items: center;
      color: var(--quiet);
      font-family: var(--sans);
      background: #050505;
    }

    .feature-label {
      margin: 0 0 18px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
    }

    .feature-title {
      margin: 0;
      max-width: 900px;
      font-family: var(--display);
      font-size: clamp(3.3rem, 5.6vw, 6.8rem);
      line-height: 0.92;
      font-weight: 400;
      letter-spacing: 0.01em;
    }

    .meta {
      margin: 24px 0 34px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      line-height: 1.8;
    }

    .essay {
      max-width: 72ch;
      color: var(--body);
      font-family: var(--serif);
      font-size: clamp(1.08rem, 1.18vw, 1.22rem);
      line-height: 1.9;
    }

    .essay :global(p) {
      margin: 0 0 1.35em;
    }

    .essay :global(p:first-child) {
      margin-top: 0;
    }

    .essay :global(h2),
    .essay :global(h3) {
      margin: 2em 0 0.7em;
      color: var(--text);
      font-family: var(--display);
      font-weight: 400;
      line-height: 1.05;
    }

    .essay :global(h2) {
      font-size: 2.4rem;
    }

    .essay :global(h3) {
      font-size: 1.9rem;
    }

    .essay :global(blockquote) {
      margin: 2em 0;
      padding: 0 0 0 1.3em;
      border-left: 1px solid var(--gold);
      color: #efe4d2;
      font-style: italic;
    }

    .score {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      margin-top: 22px;
      min-height: 46px;
      padding: 0 16px;
      border: 1px solid rgba(199, 164, 93, 0.38);
      color: var(--gold);
      background: rgba(199, 164, 93, 0.07);
      font-family: var(--sans);
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .score strong {
      color: var(--text);
    }

    .reviews {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px;
    }

    .review {
      border: 1px solid var(--line);
      background: var(--panel);
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }

    .review:hover {
      transform: translateY(-4px);
      border-color: var(--line-strong);
      background: var(--panel-strong);
    }

    .review img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      filter: saturate(0.9) contrast(1.04);
    }

    .review-body {
      padding: 26px;
      border-top: 1px solid var(--line);
    }

    .review h3 {
      margin: 0;
      font-family: var(--display);
      font-size: 2.2rem;
      line-height: 0.98;
      font-weight: 400;
    }

    .review p {
      margin: 18px 0 0;
      color: var(--body);
      font-size: 1rem;
      line-height: 1.7;
    }

    .archive {
      border: 1px solid var(--line);
      background: var(--panel);
    }

    .archive-tools {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 18px;
      align-items: center;
      padding: 24px;
      border-bottom: 1px solid var(--line);
    }

    #searchBar {
      width: 100%;
      min-height: 56px;
      border: 1px solid var(--line);
      border-radius: 0;
      padding: 0 18px;
      color: var(--text);
      background: rgba(0, 0, 0, 0.22);
      font-family: var(--sans);
      font-size: 0.92rem;
      outline: none;
    }

    #searchBar:focus {
      border-color: rgba(199, 164, 93, 0.72);
    }

    .archive-count {
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .archive-header,
    .archive-row {
      display: grid;
      grid-template-columns: 2fr 1.35fr 0.7fr 0.7fr;
      gap: 18px;
      align-items: center;
    }

    .archive-header {
      padding: 16px 24px;
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--line);
    }

    .archive-row {
      padding: 21px 24px;
      border-bottom: 1px solid rgba(240, 234, 223, 0.07);
    }

    .archive-row:last-child {
      border-bottom: 0;
    }

    .archive-row:hover {
      background: rgba(255, 255, 255, 0.035);
    }

    .archive-title {
      font-family: var(--display);
      font-size: 1.55rem;
      line-height: 1.05;
    }

    .archive-director,
    .archive-year {
      color: var(--body);
      font-family: var(--sans);
      font-size: 0.88rem;
    }

    .archive-rating {
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .empty,
    .no-results {
      padding: 46px 24px;
      color: var(--muted);
      text-align: center;
      font-family: var(--sans);
    }

    .no-results {
      display: none;
    }

    footer {
      padding: 42px 0 58px;
      color: var(--quiet);
      font-family: var(--sans);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-align: center;
      text-transform: uppercase;
    }

    @media (max-width: 980px) {
      .shell {
        width: min(100% - 28px, 1440px);
      }

      .topbar-inner {
        min-height: auto;
        padding: 22px 0;
        align-items: flex-start;
        flex-direction: column;
      }

      .nav {
        flex-wrap: wrap;
        white-space: normal;
        gap: 10px 14px;
        line-height: 1.5;
        letter-spacing: 0.16em;
      }

      h1 {
        white-space: normal;
        font-size: clamp(4.2rem, 19vw, 7rem);
      }

      .hero-copy,
      .feature,
      .reviews {
        grid-template-columns: 1fr;
      }

      .intro {
        max-width: 100%;
      }

      .poster-empty {
        min-height: 380px;
      }

      .archive-tools {
        grid-template-columns: 1fr;
      }

      .archive-header {
        display: none;
      }

      .archive-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .archive-director::before {
        content: "Director: ";
        color: var(--quiet);
      }

      .archive-year::before {
        content: "Year: ";
        color: var(--quiet);
      }

      .archive-rating::before {
        content: "Score: ";
        color: var(--quiet);
      }
    }
  </style>
</head>

<body>
  <div class="shell">
    <nav class="topbar" aria-label="Primary navigation">
      <div class="topbar-inner">
        <a class="brand" href="#">Mise-en-Scène</a>

        <div class="nav">
          <a href="#featured">Featured Essay</a>
          <span class="dot">•</span>
          <a href="#recent">Recent Notes</a>
          <span class="dot">•</span>
          <a href="#archive">Archive</a>
        </div>
      </div>
    </nav>

    <header class="hero">
      <p class="eyebrow">A cinema journal by Cayden Mcguire Surrency</p>
      <h1>Mise-en-Scène</h1>

      <div class="hero-copy">
        <p class="intro">
          Essays on films that remain after the final frame: studies of atmosphere,
          performance, composition, silence, obsession, and the strange emotional
          weather of cinema.
        </p>

        <p class="note">
          Close readings, critical essays, and personal notes on the art of looking.
        </p>
      </div>
    </header>

    <main>
      <section id="featured">
        <div class="section-title">
          <span>Featured Essay</span>
        </div>

        {featured ? (
          <div class="feature">
            <div class="poster">
              {featured.poster ? (
                <img src={featured.poster} alt={`Poster for ${featured.title}`} loading="eager" />
              ) : (
                <div class="poster-empty">No Poster Available</div>
              )}
            </div>

            <article>
              <p class="feature-label">Current Film</p>
              <h2 class="feature-title">{featured.title}</h2>

              <div class="meta">
                {featured.year} / Directed by {featured.director}
              </div>

              <div class="essay">
                {FeaturedContent ? <FeaturedContent /> : <p>{featured.excerpt}</p>}
              </div>

              <div class="score">
                Review Score <strong>{featured.rating} / 4.0</strong>
              </div>
            </article>
          </div>
        ) : (
          <div class="empty">The journal is currently awaiting its first essay.</div>
        )}
      </section>

      <section id="recent">
        <div class="section-title">
          <span>Recent Notes</span>
        </div>

        {recent.length > 0 ? (
          <div class="reviews">
            {recent.map((post) => (
              <article class="review">
                {post.poster ? (
                  <img src={post.poster} alt={`Poster for ${post.title}`} loading="lazy" />
                ) : (
                  <div class="poster-empty">No Poster</div>
                )}

                <div class="review-body">
                  <h3>{post.title}</h3>
                  <div class="meta">
                    {post.year} / {post.director} / {post.rating} out of 4
                  </div>
                  <p>{post.excerpt}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty">No recent notes have been cataloged yet.</div>
        )}
      </section>

      <section id="archive">
        <div class="section-title">
          <span>Archive</span>
        </div>

        <div class="archive">
          <div class="archive-tools">
            <input
              type="search"
              id="searchBar"
              placeholder="Search by film, director, or year"
              aria-label="Search the archive"
            />
            <div class="archive-count">{entries.length} entries</div>
          </div>

          <div class="archive-header">
            <div>Film</div>
            <div>Director</div>
            <div>Year</div>
            <div>Score</div>
          </div>

          <div id="archiveCatalog">
            {entries.map((post) => (
              <div
                class="archive-row"
                data-title={post.title}
                data-director={post.director}
                data-year={post.year}
              >
                <div class="archive-title">{post.title}</div>
                <div class="archive-director">{post.director}</div>
                <div class="archive-year">{post.year}</div>
                <div class="archive-rating">{post.rating} / 4.0</div>
              </div>
            ))}
          </div>

          <div class="no-results" id="noResults">
            No entries match your search.
          </div>
        </div>
      </section>
    </main>

    <footer>
      Edited and published by Cayden Mcguire Surrency / © 2026 Mise-en-Scène
    </footer>
  </div>

  <script>
    const searchBar = document.getElementById('searchBar');
    const archiveCatalog = document.getElementById('archiveCatalog');
    const noResults = document.getElementById('noResults');

    if (searchBar && archiveCatalog && noResults) {
      const rows = Array.from(archiveCatalog.querySelectorAll('.archive-row'));

      searchBar.addEventListener('input', () => {
        const query = searchBar.value.toLowerCase().trim();
        let matches = 0;

        rows.forEach((row) => {
          const title = row.getAttribute('data-title')?.toLowerCase() || '';
          const director = row.getAttribute('data-director')?.toLowerCase() || '';
          const year = row.getAttribute('data-year')?.toLowerCase() || '';

          const visible =
            title.includes(query) ||
            director.includes(query) ||
            year.includes(query);

          row.style.display = visible ? 'grid' : 'none';

          if (visible) matches += 1;
        });

        noResults.style.display = matches === 0 && query !== '' ? 'block' : 'none';
      });
    }
  </script>
</body>
</html>
