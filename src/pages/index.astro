---
// Fetch all markdown dispatches dynamically
const posts = await Astro.glob('./posts/*.md');

// Sort posts chronologically (Newest First)
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date || 0) - new Date(a.frontmatter.date || 0));

// Editorial Hierarchy Filtering
const leadFeature = sortedPosts.find(post => post.frontmatter.featured === true) || sortedPosts[0];
const secondaryFeatures = sortedPosts.filter(post => post.frontmatter.featured !== true).slice(0, 3);
const archivalCatalog = sortedPosts; 
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Mise-en-Scène | Film Journal</title>
	
	<script type="application/ld+json" define:vars={{ 
		title: leadFeature?.frontmatter?.title || "Mise-en-Scène", 
		director: leadFeature?.frontmatter?.director || "Cinema",
		year: leadFeature?.frontmatter?.year || "2026",
		rating: leadFeature?.frontmatter?.rating || "4.0"
	}}>
	{
	  "@context": "https://schema.org/",
	  "@type": "Review",
	  "itemReviewed": {
	    "@type": "Movie",
	    "name": title,
	    "director": {
	      "@type": "Person",
	      "name": director
	    },
	    "dateCreated": year
	  },
	  "reviewRating": {
	    "@type": "Rating",
	    "ratingValue": rating,
	    "bestRating": "4.0",
	    "worstRating": "0.0"
	  },
	  "author": {
	    "@type": "Person",
	    "name": "Cayden Mcguire Surrency"
	  },
	  "publisher": {
	    "@type": "Organization",
	    "name": "Mise-en-Scène",
	    "url": "https://your-movie-journal.vercel.app"
	  }
	}
	</script>

