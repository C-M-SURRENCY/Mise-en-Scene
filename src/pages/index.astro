---
const posts = await Astro.glob('./posts/*.md');

const sortedPosts = posts
  .map((post) => ({
    ...post,
    title: post.frontmatter.title || 'Untitled Film',
    director: post.frontmatter.director || 'Unknown Director',
    year: post.frontmatter.year || 'Unknown Year',
    rating: post.frontmatter.rating || 'Unrated',
    poster: post.frontmatter.poster || '',
    description:
      post.frontmatter.description ||
      post.frontmatter.summary ||
      post.frontmatter.excerpt ||
      'A critical dispatch from the archive.',
    date: post.frontmatter.date || '1900-01-01',
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const leadFeature =
  sortedPosts.find((post) => post.frontmatter.featured === true) ||
  sortedPosts[0] ||
  null;

const LeadContent = leadFeature?.Content;
const secondaryFeatures = sortedPosts.filter((post) => post !== leadFeature).slice(0, 3);
const archivalCatalog = sortedPosts;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mise-en-Scène | Film Journal</title>
  <meta
    name="description"
    content="Mise-en-Scène is a curated film journal of reviews, criticism, and cinematic dispatches."
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Mise-en-Scène",
    "url": "https://mise-en-scene-sable.vercel.app",
    "publisher": {
      "@type": "Organization",
      "name": "Mise-en-Scène"
    }
  })} />

  <style>
    :root {
      --bg: #101416;
      --surface: #151b1f;
      --surface-2: #1d2429;
      --ink: #f4efe6;
      --muted: #9da7ad;
      --soft: #c9d0d4;
      --line: rgba(255, 255, 255, 0.1);
      --line-strong: rgba(255, 255, 255, 0.18);
      --gold: #d8b36a;
      --red: #6f3438;
      --shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
      --serif: Georgia, "Times New Roman", serif;
      --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      background: var(--bg);
    }

    body {
      margin: 0;
      color: var(--ink);
      font-family: var(--serif);
      line-height: 1.65;
      background:
        linear-gradient(180deg, rgba(111, 52, 56, 0.58) 0, rgba(111, 52, 56, 0.2) 18px, transparent 18px),
        radial-gradient(circle at 18% 0%, rgba(216, 179, 106, 0.08), transparent 34rem),
        linear-gradient(180deg, #151a1e 0%, #101416 42%, #0c1012 100%);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    .site-shell {
      width: min(1550px, calc(100% - 48px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 18px;
      z-index: 20;
      margin-top: 18px;
      border: 1px solid var(--line);
      background: rgba(13, 18, 20, 0.84);
      backdrop-filter: blur(18px);
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
    }

    .topbar-inner {
      min-height: 74px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
      padding: 0 30px;
    }

    .brand {
      font-family: var(--sans);
      font-size: 0.92rem;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav-links {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 18px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.76rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .nav-links a {
      transition: color 180ms ease;
    }

    .nav-links a:hover {
      color: var(--ink);
    }

    .nav-dot {
      color: rgba(216, 179, 106, 0.72);
      letter-spacing: 0;
    }

    .hero {
      min-height: 420px;
      display: grid;
      align-items: end;
      padding: 92px 0 74px;
      border-bottom: 1px solid var(--line);
    }

    .kicker {
      margin: 0 0 18px;
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.74rem;
      letter-spacing: 0.34em;
      text-transform: uppercase;
    }

    h1 {
      max-width: 1050px;
      margin: 0;
      font-size: clamp(3.8rem, 10vw, 9.6rem);
      line-height: 0.9;
      font-weight: 400;
      letter-spacing: 0;
    }

    .tagline {
      max-width: 760px;
      margin: 28px 0 0;
      color: var(--soft);
      font-family: var(--sans);
      font-size: clamp(1rem, 1.5vw, 1.18rem);
      line-height: 1.75;
    }

    section {
      padding: 74px 0;
      border-bottom: 1px solid var(--line);
    }

    .section-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 34px;
      font-family: var(--sans);
      color: var(--muted);
      font-size: 0.75rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    .section-heading::after {
      content: "";
      height: 1px;
      flex: 1;
      background: var(--line);
    }

    .lead-grid {
      display: grid;
      grid-template-columns: minmax(300px, 0.92fr) minmax(360px, 1.08fr);
      gap: clamp(34px, 5vw, 78px);
      align-items: center;
    }

    .poster-frame {
      overflow: hidden;
      border: 1px solid var(--line-strong);
      background: #080a0b;
      box-shadow: var(--shadow);
    }

    .poster-frame img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      opacity: 0.92;
      transition: transform 500ms ease, opacity 300ms ease;
    }

    .poster-frame:hover img {
      transform: scale(1.025);
      opacity: 1;
    }

    .poster-placeholder {
      min-height: 560px;
      display: grid;
      place-items: center;
      color: var(--muted);
      font-family: var(--sans);
      background:
        linear-gradient(135deg, rgba(216, 179, 106, 0.08), transparent),
        #080a0b;
    }

    .lead-title {
      margin: 0;
      font-size: clamp(2.5rem, 5vw, 5.2rem);
      line-height: 0.98;
      font-weight: 400;
      letter-spacing: 0;
    }

    .meta {
      margin: 18px 0 28px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.82rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .lead-copy {
      max-width: 720px;
      color: #d7ddd9;
      font-size: 1.13rem;
    }

    .lead-copy :global(p:first-child) {
      margin-top: 0;
    }

    .rating {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      margin-top: 26px;
      padding: 12px 16px;
      border: 1px solid rgba(216, 179, 106, 0.35);
      background: rgba(216, 179, 106, 0.07);
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .rating strong {
      color: var(--ink);
      letter-spacing: 0.08em;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 26px;
    }

    .card {
      border: 1px solid var(--line);
      background: rgba(21, 27, 31, 0.74);
      transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
    }

    .card:hover {
      transform: translateY(-5px);
      border-color: var(--line-strong);
      background: rgba(29, 36, 41, 0.9);
    }

    .card-image {
      background: #080a0b;
      border-bottom: 1px solid var(--line);
    }

    .card-image img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      opacity: 0.9;
    }

    .card-body {
      padding: 24px;
    }

    .card h3 {
      margin: 0;
      font-size: clamp(1.55rem, 2vw, 2rem);
      line-height: 1.08;
      font-weight: 400;
    }

    .card p {
      margin: 18px 0 0;
      color: var(--soft);
      font-size: 1rem;
    }

    .archive-panel {
      border: 1px solid var(--line);
      background: rgba(21, 27, 31, 0.72);
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
    }

    .archive-tools {
      padding: 24px;
      border-bottom: 1px solid var(--line);
    }

    #searchBar {
      width: 100%;
      min-height: 54px;
      border: 1px solid var(--line);
      border-radius: 0;
      padding: 0 18px;
      color: var(--ink);
      background: rgba(9, 12, 14, 0.72);
      font-family: var(--sans);
      font-size: 0.9rem;
      outline: none;
    }

    #searchBar:focus {
      border-color: rgba(216, 179, 106, 0.62);
    }

    .archive-header,
    .archive-row {
      display: grid;
      grid-template-columns: 2fr 1.35fr 0.7fr 0.7fr;
      gap: 18px;
      align-items: center;
    }

    .archive-header {
      padding: 16px 24px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.7rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--line);
    }

    .archive-row {
      padding: 19px 24px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.065);
      transition: background 180ms ease;
    }

    .archive-row:hover {
      background: rgba(255, 255, 255, 0.035);
    }

    .archive-row:last-child {
      border-bottom: 0;
    }

    .archive-title {
      font-size: 1.22rem;
    }

    .archive-director,
    .archive-year {
      color: var(--soft);
      font-family: var(--sans);
      font-size: 0.88rem;
    }

    .archive-rating {
      color: var(--gold);
      font-family: var(--sans);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .empty,
    .no-results {
      padding: 42px 24px;
      color: var(--muted);
      text-align: center;
      font-family: var(--sans);
    }

    .no-results {
      display: none;
    }

    footer {
      padding: 38px 0 52px;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.74rem;
      letter-spacing: 0.22em;
      text-align: center;
      text-transform: uppercase;
    }

    @media (max-width: 900px) {
      .site-shell {
        width: min(100% - 28px, 1550px);
      }

      .topbar {
        top: 10px;
        margin-top: 10px;
      }

      .topbar-inner {
        min-height: auto;
        padding: 18px;
        align-items: flex-start;
        flex-direction: column;
      }

      .nav-links {
        width: 100%;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 10px 14px;
        white-space: normal;
        letter-spacing: 0.18em;
        line-height: 1.5;
      }

      .hero {
        min-height: 360px;
        padding: 64px 0 54px;
      }

      .lead-grid,
      .cards {
        grid-template-columns: 1fr;
      }

      .poster-placeholder {
        min-height: 380px;
      }

      .archive-header {
        display: none;
      }

      .archive-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .archive-director::before {
        content: "Director: ";
        color: var(--muted);
      }

      .archive-year::before {
        content: "Year: ";
        color: var(--muted);
      }

      .archive-rating::before {
        content: "Score: ";
        color: var(--muted);
      }
    }
  </style>
</head>

<body>
  <div class="site-shell">
    <nav class="topbar" aria-label="Primary navigation">
      <div class="topbar-inner">
        <a class="brand" href="#">Mise-en-Scène</a>

        <div class="nav-links">
          <a href="#featured">Featured Review</a>
          <span class="nav-dot">•</span>
          <a href="#recent">Recent Additions</a>
          <span class="nav-dot">•</span>
          <a href="#archive">The Archive</a>
        </div>
      </div>
    </nav>

    <header class="hero">
      <div>
        <p class="kicker">Film criticism and visual essays</p>
        <h1>Mise-en-Scène</h1>
        <p class="tagline">
          A curated journal for modern cinema, built around atmosphere, authorship,
          performance, and the images that refuse to leave the mind.
        </p>
      </div>
    </header>

    <main>
      <section id="featured">
        <div class="section-heading">
          <span>Featured Analysis</span>
        </div>

        {leadFeature ? (
          <div class="lead-grid">
            <div class="poster-frame">
              {leadFeature.poster ? (
                <img src={leadFeature.poster} alt={`Poster for ${leadFeature.title}`} loading="eager" />
              ) : (
                <div class="poster-placeholder">No Poster Available</div>
              )}
            </div>

            <article>
              <h2 class="lead-title">{leadFeature.title}</h2>
              <div class="meta">
                {leadFeature.year} / Directed by {leadFeature.director}
              </div>

              <div class="lead-copy">
                {LeadContent ? <LeadContent /> : <p>{leadFeature.description}</p>}
              </div>

              <div class="rating">
                Review Score <strong>{leadFeature.rating} / 4.0</strong>
              </div>
            </article>
          </div>
        ) : (
          <div class="empty">
            The editorial catalog is currently empty. Add markdown reviews to begin.
          </div>
        )}
      </section>

      <section id="recent">
        <div class="section-heading">
          <span>Recent Additions</span>
        </div>

        {secondaryFeatures.length > 0 ? (
          <div class="cards">
            {secondaryFeatures.map((post) => (
              <article class="card">
                <div class="card-image">
                  {post.poster ? (
                    <img src={post.poster} alt={`Poster for ${post.title}`} loading="lazy" />
                  ) : (
                    <div class="poster-placeholder">No Poster</div>
                  )}
                </div>

                <div class="card-body">
                  <h3>{post.title}</h3>
                  <div class="meta">
                    {post.year} / {post.director} / {post.rating} out of 4
                  </div>
                  <p>{post.description}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty">No recent auxiliary essays cataloged.</div>
        )}
      </section>

      <section id="archive">
        <div class="section-heading">
          <span>The Archive</span>
        </div>

        <div class="archive-panel">
          <div class="archive-tools">
            <input
              type="search"
              id="searchBar"
              placeholder="Search by film, director, or year"
              aria-label="Search archive"
            />
          </div>

          <div class="archive-header">
            <div>Film Title</div>
            <div>Director</div>
            <div>Year</div>
            <div>Score</div>
          </div>

          <div id="archiveCatalog">
            {archivalCatalog.map((post) => (
              <div
                class="archive-row"
                data-title={post.title}
                data-director={post.director}
                data-year={post.year}
              >
                <div class="archive-title">{post.title}</div>
                <div class="archive-director">{post.director}</div>
                <div class="archive-year">{post.year}</div>
                <div class="archive-rating">{post.rating} / 4.0</div>
              </div>
            ))}
          </div>

          <div class="no-results" id="noResults">
            No entries match your search.
          </div>
        </div>
      </section>
    </main>

    <footer>
      Edited and published by Cayden Mcguire Surrency / © 2026 Mise-en-Scène
    </footer>
  </div>

  <script>
    const searchBar = document.getElementById('searchBar');
    const archiveCatalog = document.getElementById('archiveCatalog');
    const noResults = document.getElementById('noResults');

    if (searchBar && archiveCatalog && noResults) {
      const rows = Array.from(archiveCatalog.querySelectorAll('.archive-row'));

      searchBar.addEventListener('input', () => {
        const query = searchBar.value.toLowerCase().trim();
        let matches = 0;

        rows.forEach((row) => {
          const title = row.getAttribute('data-title')?.toLowerCase() || '';
          const director = row.getAttribute('data-director')?.toLowerCase() || '';
          const year = row.getAttribute('data-year')?.toLowerCase() || '';

          const visible =
            title.includes(query) ||
            director.includes(query) ||
            year.includes(query);

          row.style.display = visible ? 'grid' : 'none';

          if (visible) {
            matches += 1;
          }
        });

        noResults.style.display = matches === 0 && query !== '' ? 'block' : 'none';
      });
    }
  </script>
</body>
</html>
