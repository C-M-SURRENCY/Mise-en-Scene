---
const posts = await Astro.glob('./posts/*.md');
---
<html lang="en">
<head>
	<meta charset="utf-8" />
	<title>Mise-en-Scène</title>
	<style>
		body { background: #050505; color: #e5e5e5; font-family: serif; max-width: 600px; margin: 40px auto; padding: 0 20px; }
		h1 { font-weight: normal; letter-spacing: -1px; border-bottom: 1px solid #222; padding-bottom: 10px; }
		.post { margin-bottom: 40px; }
		a { color: #999; text-decoration: none; }
		a:hover { color: #fff; }
	</style>
</head>
<body>
	<h1>Mise-en-Scène</h1>
	{posts.map(post => (
		<div class="post">
			<h2>{post.frontmatter.title} ({post.frontmatter.year})</h2>
			<p><em>Directed by {post.frontmatter.director}</em></p>
			<article><post.Content /></article>
		</div>
	))}
</body>
</html>
